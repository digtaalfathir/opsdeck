{
  "name": "opsdeck",
  "productName": "Opsdeck",
  "version": "2.0.0",
  "description": "Watch and reach every machine from one deck — hardware monitoring + remote SSH/VNC in one console.",
  "author": "Rifky Andigta Al-Fathir",
  "license": "MIT",
  "copyright": "Copyright © 2026 Rifky Andigta Al-Fathir",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac",
    "make:icon": "node build/make-icon.js",
    "make:remotes-portable": "CONVERT_REMOTES=1 electron ."
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@novnc/novnc": "^1.4.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "ssh2": "^1.15.0",
    "ws": "^8.16.0"
  },
  "build": {
    "appId": "com.opsdeck.app",
    "productName": "Opsdeck",
    "copyright": "Copyright © 2026 Rifky Andigta Al-Fathir",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "asar": false,
    "files": [
      "**/*",
      "!**/*.bak",
      "!try/**",
      "!scripts/**",
      "!dist/**",
      "!DEPLOYMENT.md"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Opsdeck",
      "uninstallDisplayName": "Opsdeck",
      "artifactName": "Opsdeck-Setup-${version}.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "maintainer": "Rifky Andigta Al-Fathir",
      "artifactName": "Opsdeck-${version}.${ext}"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.utilities"
    }
  }
}
