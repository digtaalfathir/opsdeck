{
  "name": "stechoq-ops-center",
  "productName": "Stechoq Ops Center",
  "version": "2.0.0",
  "description": "Stechoq Ops Center — monitoring hardware & remote (VNC/SSH) untuk jaringan internal Stechoq.",
  "author": {
    "name": "Stechoq",
    "email": "support@stechoq.com"
  },
  "license": "UNLICENSED",
  "copyright": "Copyright © 2026 Stechoq. Internal use only.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac",
    "make:icon": "node build/make-icon.js"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@novnc/novnc": "^1.4.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "ssh2": "^1.15.0",
    "ws": "^8.16.0"
  },
  "build": {
    "appId": "com.stechoq.opscenter",
    "productName": "Stechoq Ops Center",
    "copyright": "Copyright © 2026 Stechoq. Internal use only.",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "asar": false,
    "files": [
      "**/*",
      "!**/*.bak",
      "!try/**",
      "!scripts/**",
      "!dist/**",
      "!DEPLOYMENT.md",
      "!remotes.json",
      "!layout.json"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stechoq Ops Center",
      "uninstallDisplayName": "Stechoq Ops Center",
      "artifactName": "StechoqOpsCenter-Setup-${version}.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "maintainer": "Stechoq <support@stechoq.com>",
      "artifactName": "StechoqOpsCenter-${version}.${ext}"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.utilities"
    }
  }
}
